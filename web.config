<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS + iisnode configuration for Azure App Service (Windows).
  Copied into .next/standalone/ by the deploy workflow.

  - Requests under /_next/static/* and common static asset extensions are
    served by IIS directly (faster, no Node hop).
  - Everything else is rewritten to server.js, which Next.js's standalone
    output handles (pages, API routes, favicon, dynamic assets).
-->
<configuration>
  <system.webServer>
    <webSocket enabled="false" />

    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <rule name="StaticContent" stopProcessing="true">
          <match url="^(_next/static/.*|.*\.(?:png|jpg|jpeg|gif|svg|webp|ico|txt|woff|woff2|ttf|eot|map))$" />
          <action type="None" />
        </rule>
        <rule name="DynamicContent">
          <match url="/*" />
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>

    <iisnode
      nodeProcessCountPerApplication="1"
      maxConcurrentRequestsPerProcess="1024"
      loggingEnabled="true"
      devErrorsEnabled="false" />

    <httpErrors existingResponse="PassThrough" />
  </system.webServer>
</configuration>
