<?xml version="1.0" encoding="utf-8"?>
<!--
  Azure App Service (Windows, Node) configuration for Next.js standalone.

  Uses httpPlatformHandler (not iisnode): IIS launches `node.exe server.js`
  as a child process, injects a dynamic PORT via HTTP_PLATFORM_PORT, and
  proxies all HTTP requests to it. Next.js standalone reads process.env.PORT
  and listens there.

  Copied into .next/standalone/ by the deploy workflow.
-->
<configuration>
  <system.webServer>
    <handlers>
      <add name="httpPlatformHandler"
           path="*"
           verb="*"
           modules="httpPlatformHandler"
           resourceType="Unspecified" />
    </handlers>

    <httpPlatform processPath="node.exe"
                  arguments="server.js"
                  stdoutLogEnabled="true"
                  stdoutLogFile="\\?\%home%\LogFiles\nodejs\stdout"
                  startupTimeLimit="60"
                  requestTimeout="00:04:00">
      <environmentVariables>
        <environmentVariable name="PORT" value="%HTTP_PLATFORM_PORT%" />
        <environmentVariable name="HOSTNAME" value="127.0.0.1" />
        <environmentVariable name="NODE_ENV" value="production" />
      </environmentVariables>
    </httpPlatform>

    <httpErrors existingResponse="PassThrough" />
  </system.webServer>
</configuration>
